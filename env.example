# Copiá a .env.local y completá.
# Supabase → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Backoffice: contraseña de acceso + secreto para firmar la cookie de sesión.
# Generá un BACKOFFICE_AUTH_SECRET largo y aleatorio (no lo compartas).
BACKOFFICE_PASSWORD=
BACKOFFICE_AUTH_SECRET=

# Solo desarrollo local: desactiva login y middleware del BO (no usar en producción).
# SKIP_BO_AUTH=true

# ——— Imágenes (Cloudflare R2, API S3) ———
# Dashboard R2 → bucket → Settings → S3 API (Account ID + tokens).
# Dominio público: conectá un custom domain al bucket o usá la URL pública r2.dev.
#
# Producción (p. ej. Vercel): las cinco variables deben existir para "Production".
# Si las cargás solo en Preview/Development, el deploy de prod no las ve. Tras agregar
# o cambiar NEXT_PUBLIC_* hacé un redeploy (el build inyecta parte de la config).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Sin barra final. Ej: https://media.tudominio.com  o  https://pub-xxxxx.r2.dev
# Importante para la tienda: Next.js <Image> solo permite hosts declarados en build.
# Definí la misma URL base en Vercel/hosting antes de `npm run build` (o reiniciá `next dev` al cambiarla).
# Las URLs `*.r2.dev` ya están permitidas en next.config; un dominio custom debe coincidir con este valor.
NEXT_PUBLIC_MEDIA_URL_BASE=

# Legacy Supabase Storage: solo sirve para borrar ítems de galería cargados antes de R2
# (mismo bucket que en migración 002). Las subidas nuevas van siempre a R2.
# NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=product-images
